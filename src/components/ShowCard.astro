---
import type { EnrichedShow } from '../lib/enrich/types';

interface Props {
  show: EnrichedShow;
  categorySlug: string;
  categoryIndex: number;
}

const { show, categorySlug, categoryIndex } = Astro.props;

const palette = [
  '#0050b3', '#4d1a6e', '#9d0049', '#b35900',
  '#0e5c3b', '#0d5a6e', '#7a1f4d', '#5c2e8c',
  '#7a6200', '#2d3d8c',
];
const placeholderColor = palette[categoryIndex % palette.length];
const serviceLabel = (() => {
  if (show.resolvedUrl.includes('crunchyroll.com')) return 'Crunchyroll';
  if (show.resolvedUrl.includes('hidive.com')) return 'HIDIVE';
  if (show.resolvedUrl.includes('netflix.com')) return 'Netflix';
  if (show.resolvedUrl.includes('amazon.com') || show.resolvedUrl.includes('primevideo.com')) return 'Amazon Prime';
  if (show.resolvedUrl.includes('aniplus')) return 'ANIPLUS';
  if (show.resolvedUrl.includes('myanimelist.net')) return 'MyAnimeList';
  if (show.source === 'unresolved') return 'Link TBA';
  return 'Watch';
})();

const coverSrc = show.coverPath
  ? `${import.meta.env.BASE_URL}${show.coverPath.replace(/^\//, '')}`
  : null;
---

<article class="card" data-source={show.source}>
  <div class="cover" style={coverSrc ? undefined : `background:${placeholderColor}`}>
    {coverSrc
      ? <img src={coverSrc} alt={show.title} loading="lazy" width="240" height="340" />
      : <div class="cover-placeholder">{show.title}</div>
    }
  </div>
  <div class="card-body">
    <h3 class="title">
      {show.title}
      {show.markers.includes('continuing') && <span class="badge badge-continuing">Continuing</span>}
      {show.markers.includes('movie') && <span class="badge badge-movie">Movie</span>}
    </h3>
    {show.blurb && <p class="blurb">{show.blurb}</p>}
    <a class="link" href={show.resolvedUrl} target="_blank" rel="noopener noreferrer">
      {serviceLabel} ↗
    </a>
  </div>
</article>

<style>
.card {
  display: flex;
  flex-direction: column;
  background: var(--surface);
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--border);
  transition: transform 0.15s ease, border-color 0.15s ease;
}
.card:hover { transform: translateY(-2px); border-color: var(--accent); }
.cover {
  aspect-ratio: 240 / 340;
  width: 100%;
  overflow: hidden;
  background: var(--surface-alt);
}
.cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
.cover-placeholder {
  display: flex; align-items: center; justify-content: center;
  height: 100%; padding: 1rem; color: var(--text); font-weight: 600;
  text-align: center; font-size: 0.95rem; line-height: 1.3;
}
.card-body { padding: 0.875rem 1rem 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
.title {
  margin: 0; font-size: 1rem; line-height: 1.3; font-weight: 600;
  display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem;
  color: var(--text);
}
.blurb {
  margin: 0; font-size: 0.85rem; line-height: 1.45; color: var(--muted);
  display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
}
.link {
  margin-top: auto; font-size: 0.85rem; font-weight: 600;
  color: var(--accent-link); text-decoration: none; padding: 0.5rem 0; min-height: 44px;
  display: inline-flex; align-items: center;
}
.link:hover { text-decoration: underline; color: var(--text); }
.badge {
  font-family: var(--font-mono);
  font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
  padding: 0.15rem 0.45rem; border-radius: 999px; white-space: nowrap;
  border: 1px solid var(--border);
}
.badge-continuing { background: var(--surface-alt); color: var(--muted); }
.badge-movie { background: var(--surface-alt); color: var(--muted); }
</style>